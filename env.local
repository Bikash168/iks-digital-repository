# FILE: .env.local  (in your project root — never commit this to git)

# Leave VERCEL unset locally so the API route uses the local filesystem.
# On Vercel, this token is injected automatically when you link a Blob store.
# Uncomment the line below ONLY if you want to test Vercel Blob locally:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx
